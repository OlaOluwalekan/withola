generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SkillCategory {
  PROGRAMMING_LANGUAGE
  FRONTEND
  BACKEND
  DATABASE
  MOBILE
  DEVOPS
  DESIGN
  SOFT_SKILL
  OTHER
}

enum WorkLocationType {
  REMOTE
  ONSITE
  HYBRID
}

enum WorkType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  title          String
  isFeatured     Boolean  @default(false)
  tags           String[]
  technologies   String[]
  majorFeature   String
  description    String
  readme         String   @db.Text
  sourceCodeLink String?
  liveUrlLink    String?
  icon           String
  screenShots    String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Skill {
  id         String        @id @default(cuid())
  name       String
  emojiIcon  String
  competency Int
  category   SkillCategory
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model WorkExperience {
  id               String           @id @default(cuid())
  jobTitle         String
  company          String
  startDate        DateTime
  endDate          DateTime?
  companyLocation  String
  workLocationType WorkLocationType
  workType         WorkType
  responsibilities String[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Message {
  id          String   @id @default(cuid())
  senderName  String
  senderEmail String
  subject     String
  content     String   @db.Text
  attachments String[]
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}
